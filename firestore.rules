rules_version = '2';

// Upmark Firestore Security Rules
// Deploy via Firebase Console or Firebase CLI: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Case Studies ─────────────────────────────────
    // Read: anyone (for public website).
    // Write: only authenticated users (admin panel).
    match /case_studies/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ─── Services ─────────────────────────────────────
    // Read: anyone (for public website).
    // Write: only authenticated users (admin panel).
    match /services/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ─── Leads ────────────────────────────────────────
    // Read: only authenticated users (admin panel).
    // Write (create): via Firebase Admin SDK in the API route (bypasses rules).
    //        No client-side writes allowed.
    match /leads/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK bypasses this; blocks client writes.
    }
    // ─── Settings ─────────────────────────────────────
    // Read: anyone (for public website).
    // Write: only authenticated users (admin panel).
    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ─── Work Items ───────────────────────────────────
    // Read: anyone (for public website).
    // Write: only authenticated users (admin panel).
    match /work/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ─── Testimonials ─────────────────────────────────
    // Read: anyone (for public website).
    // Write: only authenticated users (admin panel).
    match /testimonials/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
